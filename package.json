{
  "name": "rest-express",
  "version": "1.0.0",
  "type": "module",
  "license": "MIT",
  "scripts": {
    "test": "npx tsx --test server/__tests__/*.test.ts",
    "eval:offline": "npx tsx eval/runner.ts",
    "seed:golden": "cross-env NODE_ENV=production tsx -r dotenv/config scripts/seedGolden.ts",
    "eval:golden": "cross-env NODE_ENV=production tsx -r dotenv/config eval/golden/runner.ts",
    "eval:golden-five": "cross-env NODE_ENV=production tsx -r dotenv/config scripts/golden-eval-five-dimension.ts",
    "build:dev": "vite build",
    "dev": "cross-env NODE_ENV=development tsx server/index.ts",
    "dev:dotenv": "cross-env NODE_ENV=development tsx -r dotenv/config server/index.ts",
    "build": "tsx script/build.ts",
    "start": "cross-env NODE_ENV=production node dist/index.cjs",
    "check": "tsc",
    "db:up": "tsx scripts/setupSQLite.ts",
    "db:push:pg": "npx drizzle-kit push --config=drizzle.config.ts",
    "db:push:sqlite": "cross-env NODE_ENV=development DATABASE_DIALECT=sqlite DATABASE_URL=file:.data/dev.db tsx scripts/db-push.ts",
    "db:generate": "npx drizzle-kit generate --config=drizzle.config.ts",
    "db:doctor": "tsx scripts/doctor_db.ts",
    "db:push": "tsx scripts/db-push.ts",
    "proof:scopes": "tsx scripts/proof_scopes.ts",
    "proof:scopes:all": "tsx scripts/proof_scopes_all.ts",
    "db:migrate": "tsx scripts/db-push.ts",
    "db:migrate:conversations": "tsx -r dotenv/config scripts/run_conversations_migration.ts",
    "db:proof:migrate": "cross-env PROOF_MODE=1 tsx scripts/db-push.ts",
    "db:smoke": "cross-env NODE_ENV=production tsx -r dotenv/config scripts/dbSmoke.ts",
    "proof": "cross-env PROOF_MODE=1 tsx scripts/proof.ts",
    "worker": "cross-env NODE_ENV=production tsx -r dotenv/config server/lib/jobs/runner.ts",
    "seed:e2e": "cross-env NODE_ENV=production tsx -r dotenv/config scripts/seedEval.ts",
    "eval": "cross-env NODE_ENV=production tsx -r dotenv/config eval/golden/runner.ts",
    "ci": "cross-env NODE_ENV=production tsx -r dotenv/config scripts/ciGate.ts",
    "demo:seed": "cross-env NODE_ENV=production tsx -r dotenv/config scripts/seedDemoFixture.ts",
    "demo:verify": "cross-env NODE_ENV=production EVAL_MODE=1 tsx -r dotenv/config scripts/verifyDemoQueries.ts",
    "demo:test": "npm run demo:seed && npm run demo:verify",
    "demo:clean": "cross-env NODE_ENV=production tsx -r dotenv/config scripts/cleanDemoFixture.ts",
    "verify": "npm run db:smoke && npx tsx scripts/verify_claims.ts",
    "chat-quality:backfill": "tsx scripts/backfillChatQuality.ts",
    "seed:evals": "cross-env NODE_ENV=production tsx script/seed-evals.ts",
    "test:voice": "cross-env NODE_ENV=test tsx script/test_voice_e2e.ts",
    "test:voice-smoke": "cross-env NODE_ENV=test tsx script/voice-smoke.ts",
    "test:voice-smoke:dotenv": "cross-env NODE_ENV=test tsx -r dotenv/config script/voice-smoke.ts",
    "test:mcp-smoke": "cross-env NODE_ENV=production tsx script/mcp-smoke.ts",
    "test:mcp-smoke:dotenv": "cross-env NODE_ENV=production tsx -r dotenv/config script/mcp-smoke.ts",
    "e2e:web": "tsx tests/e2e/setup-proof-db.ts && cross-env PROOF_MODE=1 npm run dev",
    "e2e:web:drop": "tsx tests/e2e/setup-proof-db.ts && cross-env PROOF_MODE=1 STREAM_SIMULATE_DROP=true NODE_ENV=development npm run dev",
    "test:okr": "cross-env NODE_ENV=production tsx -r dotenv/config scripts/verifyOKRQuery.ts",
    "mcp": "tsx server/mcp/mcpServer.ts",
    "ready": "tsx script/check_ready.ts",
    "test:rag": "npx playwright test \"tests/invariants-*.spec.ts\" \"tests/no-refusal-on-broad-queries.spec.ts\" --workers=1 --timeout=60000",
    "quality:rag": "node scripts/rag_quality_gate.cjs",
    "postinstall": "patch-package || true"
  },
  "dependencies": {
    "@hookform/resolvers": "^3.10.0",
    "@jridgewell/trace-mapping": "^0.3.25",
    "@modelcontextprotocol/sdk": "^1.25.2",
    "@radix-ui/react-accordion": "^1.2.4",
    "@radix-ui/react-alert-dialog": "^1.1.7",

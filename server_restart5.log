/1cWDQ4mEaj5ym2QFicMP-AEp4v9yg2qMK/view?usp=drivesdk","title":"Engineering_AllHands_Oct28_2024.pdf","sourceId":"d4da6b5b-9916-46cd-ac80-3ae9bc780f71","sourceType":"drive","sourceTypeLabel":"Drive"}],"citationIndexMap":{"1602cb5c-021a-4f74-9abc-944fbb22c19e":1,"d4da6b5b-9916-46cd-ac80-3ae9bc780f71":2}}},"createdAt":"2026-02-24T09:02:24.882Z"},{"id":"e16df17f-6cc6-4526-8a52-0a115faa716b","conversationId":"706ca2da-55d9-4479-8b95-eb8218d4a035","role":"user","content":"Are there any blockers for the AI search launch?","toolCallId":null,"citationsJson":null,"metadataJson":null,"createdAt":"2026-02-24T09:08:24.313Z"},{"id":"67cf7b7b-dc57-4142-8e2e-8ba9082e3cba","conversationId":"706ca2da-55d9-4479-8b95-eb8218d4a035","role":"assistant","content":"Yes, there is a critical blocker for the AI search launch concerning the AWS EU region quota. This issue involves a delayed request for an increase in the number of EC2 instances necessary for deploying the Pinecone vector database to serve European customers. - Jordan Martinez is responsible for addressing this issue, with a hard deadline set for November 11, 2024, just days before the planned launch on November 15 [12][24].\n\n- Jordan Martinez is responsible for addressing this issue, with a hard deadline set for November 11, 2024, just days before the planned launch on November 15 [12][24].\n- To mitigate the risk, the team has a fallback plan to deploy with reduced capacity, supporting 100,000 daily active users instead of the desired 200,000, if the quota is not increased in time [12][24].\n- The escalation status is critical, and the team has already escalated the issue to AWS VP level, with an executive call scheduled for November 1 if necessary [14][22].\n- The blocker affects $500,000 in annual recurring revenue from three signed enterprise contracts, highlighting its significant business impact [24].\n\nWould you like more information about how this might affect the launch timeline or other related risks?","toolCallId":null,"citationsJson":[],"metadataJson":{"response":{"answer":"Yes, there is a critical blocker for the AI search launch concerning the AWS EU region quota. This issue involves a delayed request for an increase in the number of EC2 instances necessary for deploying the Pinecone vector database to serve European customers. - Jordan Martinez is responsible for addressing this issue, with a hard deadline set for November 11, 2024, just days before the planned launch on November 15 [12][24].\n\n- Jordan Martinez is responsible for addressing this issue, with a hard deadline set for November 11, 2024, just days before the planned launch on November 15 [12][24].\n- To mitigate the risk, the team has a fallback plan to deploy with reduced capacity, supporting 100,000 daily active users instead of the desired 200,000, if the quota is not increased in time [12][24].\n- The escalation status is critical, and the team has already escalated the issue to AWS VP level, with an executive call scheduled for November 1 if necessary [14][22].\n- The blocker affects $500,000 in annual recurring revenue from three signed enterprise contracts, highlighting its significant business impact [24].\n\nWould you like more information about how this might affect the launch timeline or other related risks?","bullets":[],"sources":[{"id":"82b9fe07-ba26-415c-82ca-41614f25977e","url":"https://drive.google.com/file/d/1OaWf-KzyUEnNp_aUm9dGc9g9scyr-x0n/view?usp=drivesdk","title":"AI_Search_Architecture.pdf","sourceId":"82b9fe07-ba26-415c-82ca-41614f25977e","sourceType":"drive","sourceTypeLabel":"Drive"},{"id":"d4da6b5b-9916-46cd-ac80-3ae9bc780f71","url":"https://drive.google.com/file/d/1cWDQ4mEaj5ym2QFicMP-AEp4v9yg2qMK/view?usp=drivesdk","title":"Engineering_AllHands_Oct28_2024.pdf","sourceId":"d4da6b5b-9916-46cd-ac80-3ae9bc780f71","sourceType":"drive","sourceTypeLabel":"Drive"},{"id":"f7ada39b-e572-498c-8197-736a9a21f56f","url":"https://drive.google.com/file/d/1pcwDpaqMVClET6mfadGy_oCYn4FgigJ-/view?usp=drivesdk","title":"JIRA_INFRA-1247_AWS_EU_Blocker.pdf","sourceId":"f7ada39b-e572-498c-8197-736a9a21f56f","sourceType":"drive","sourceTypeLabel":"Drive"},{"id":"1602cb5c-021a-4f74-9abc-944fbb22c19e","url":"https://drive.google.com/file/d/1-z6r1IrvdWltGMYOjsUlg6t7A9WU6xt_/view?usp=drivesdk","title":"Product_Roadmap_2025.pdf","sourceId":"1602cb5c-021a-4f74-9abc-944fbb22c19e","sourceType":"drive","sourceTypeLabel":"Drive"},{"id":"96677b12-e487-41e8-b321-e696e442eaa2","url":"https://drive.google.com/file/d/1blwqBYR0kIAz8lgFDkzo6uRQBs0Vkkks/view?usp=drivesdk","title":"Q4_2024_OKRs.pdf","sourceId":"96677b12-e487-41e8-b321-e696e442eaa2","sourceType":"drive","sourceTypeLabel":"Drive"},{"id":"48f70248-463f-42cc-9296-330711b86ac3","url":"https://drive.google.com/file/d/1MHcvhX7gaYOpy4WPPfr8CXtrPKr1RxBJ/view?usp=drivesdk","title":"Team_Quick_Reference_Guide.pdf","sourceId":"48f70248-463f-42cc-9296-330711b86ac3","sourceType":"drive","sourceTypeLabel":"Drive"}],"citations":[],"answer_text":"Yes, there is a critical blocker for the AI search launch concerning the AWS EU region quota. This issue involves a delayed request for an increase in the number of EC2 instances necessary for deploying the Pinecone vector database to serve European customers. - Jordan Martinez is responsible for addressing this issue, with a hard deadline set for November 11, 2024, just days before the planned launch on November 15 [12][24].\n\n- Jordan Martinez is responsible for addressing this issue, with a hard deadline set for November 11, 2024, just days before the planned launch on November 15 [12][24].\n- To mitigate the risk, the team has a fallback plan to deploy with reduced capacity, supporting 100,000 daily active users instead of the desired 200,000, if the quota is not increased in time [12][24].\n- The escalation status is critical, and the team has already escalated the issue to AWS VP level, with an executive call scheduled for November 1 if necessary [14][22].\n- The blocker affects $500,000 in annual recurring revenue from three signed enterprise contracts, highlighting its significant business impact [24].\n\nWould you like more information about how this might affect the launch timeline or other related risks?","sources_used":[{"id":"82b9fe07-ba26-415c-82ca-41614f25977e","url":"https://drive.google.com/file/d/1OaWf-KzyUEnNp_aUm9dGc9g9scyr-x0n/view?usp=drivesdk","title":"AI_Search_Architecture.pdf","sourceId":"82b9fe07-ba26-415c-82ca-41614f25977e","sourceType":"drive","sourceTypeLabel":"Drive"},{"id":"d4da6b5b-9916-46cd-ac80-3ae9bc780f71","url":"https://drive.google.com/file/d/1cWDQ4mEaj5ym2QFicMP-AEp4v9yg2qMK/view?usp=drivesdk","title":"Engineering_AllHands_Oct28_2024.pdf","sourceId":"d4da6b5b-9916-46cd-ac80-3ae9bc780f71","sourceType":"drive","sourceTypeLabel":"Drive"},{"id":"f7ada39b-e572-498c-8197-736a9a21f56f","url":"https://drive.google.com/file/d/1pcwDpaqMVClET6mfadGy_oCYn4FgigJ-/view?usp=drivesdk","title":"JIRA_INFRA-1247_AWS_EU_Blocker.pdf","sourceId":"f7ada39b-e572-498c-8197-736a9a21f56f","sourceType":"drive","sourceTypeLabel":"Drive"},{"id":"1602cb5c-021a-4f74-9abc-944fbb22c19e","url":"https://drive.google.com/file/d/1-z6r1IrvdWltGMYOjsUlg6t7A9WU6xt_/view?usp=drivesdk","title":"Product_Roadmap_2025.pdf","sourceId":"1602cb5c-021a-4f74-9abc-944fbb22c19e","sourceType":"drive","sourceTypeLabel":"Drive"},{"id":"96677b12-e487-41e8-b321-e696e442eaa2","url":"https://drive.google.com/file/d/1blwqBYR0kIAz8lgFDkzo6uRQBs0Vkkks/view?usp=drivesdk","title":"Q4_2024_OKRs.pdf","sourceId":"96677b12-e487-41e8-b321-e696e442eaa2","sourceType":"drive","sourceTypeLabel":"Drive"},{"id":"48f70248-463f-42cc-9296-330711b86ac3","url":"https://drive.google.com/file/d/1MHcvhX7gaYOpy4WPPfr8CXtrPKr1RxBJ/view?usp=drivesdk","title":"Team_Quick_Reference_Guide.pdf","sourceId":"48f70248-463f-42cc-9296-330711b86ac3","sourceType":"drive","sourceTypeLabel":"Drive"}],"citationIndexMap":{}}},"createdAt":"2026-02-24T09:08:33.852Z"},{"id":"709b76cd-247d-4e8a-b05b-329ef78d3585","
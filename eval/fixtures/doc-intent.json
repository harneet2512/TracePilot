{
  "name": "doc-intent",
  "description": "Doc-intent prompts should trigger RAG and return sources",
  "cases": [
    {
      "id": "okr-query",
      "input": "What are our Q4 OKRs?",
      "assertions": {
        "answerNotEmpty": true,
        "answerContainsAny": ["OKR", "objective", "goal", "key result", "not found", "no information"],
        "sourcesDeduped": true
      }
    },
    {
      "id": "project-query",
      "input": "Find the project roadmap",
      "assertions": {
        "answerNotEmpty": true,
        "sourcesDeduped": true
      }
    },
    {
      "id": "meeting-query",
      "input": "Show me recent meeting notes",
      "assertions": {
        "answerNotEmpty": true,
        "sourcesDeduped": true
      }
    }
  ]
}

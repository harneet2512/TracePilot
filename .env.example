# Environment variables for TracePilot
# Copy this file to .env and fill in your values

# Database connection
# For tests, use: postgresql://postgres:postgres@localhost:5433/tracepilot_test
# For development with Postgres:
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/tracepilot_test
# For development with SQLite (no DATABASE_URL needed - auto-uses .data/dev.db):
# Leave DATABASE_URL unset and run: npm run db:push

# Node environment
# Set to 'test' when running tests
NODE_ENV=test

# EVAL_MODE - Strict grounding mode for evaluation scenarios ONLY
# WARNING: NEVER set this to '1' in production or runtime environments
# When EVAL_MODE=1, the system drops all items without valid citations (strict grounding)
# This is ONLY for evaluation/test scenarios to measure grounding accuracy
# Default (not set): Keeps items with invalid citations for best-effort answers
# EVAL_MODE=1

# OpenAI API Key (required for voice agent and RAG)
OPENAI_API_KEY=sk-your-key-here

# Retrieval OOM guards (prevents loading all chunks into memory)
# RETRIEVAL_TOP_K=12
# RETRIEVAL_PER_SOURCE_CAP=4
# RETRIEVAL_MAX_CANDIDATES_PG=50
# RETRIEVAL_MAX_CANDIDATES_SQLITE=1200
# RETRIEVAL_MIN_UNIQUE_SOURCES_CROSS=2

# Demo scope guard (optional)
# When DEMO_MODE=1 retrieval is hard-limited to the 6 golden demo docs.
# DEMO_SCOPE_ID narrows retrieval to sources/chunks tagged with that scopeId.
# DEMO_MODE=1
# DEMO_SCOPE_ID=demo-golden-scope

# OAuth credentials (optional, for connector integrations)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
ATLASSIAN_CLIENT_ID=
ATLASSIAN_CLIENT_SECRET=
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=

# OAuth simulator (development only, never production)
# Requires NODE_ENV=development and simulate=true query param.
OAUTH_SIMULATOR_ENABLED=false

# QA rate-limit bypass (development only, ignored in production)
# When NODE_ENV=development and the request header "x-qa-bypass" matches this token,
# the /api/chat and /api rate limiters are skipped.
# Generate a token: node -e "console.log(require('crypto').randomBytes(16).toString('hex'))"
QA_RATE_LIMIT_BYPASS_TOKEN=local-qa-token

# Extra login credential (optional, additive - does not replace DB auth)
# When set, allows login with this email/password even if user is not in DB.
# Copy to .env and set your values - do NOT commit .env with real secrets.
# APP_EXTRA_LOGIN_EMAIL=admin@tracepilot.com
# APP_EXTRA_LOGIN_PASSWORD=harneet2512

# DEV_DEBUG_UI - Show Debug tab in the Details drawer with raw JSON payloads
# When set to 1, the server includes a `debug` object in chat responses containing:
#   structured_report_raw, retrieved_chunks_raw, citation_mapping_raw
# The frontend renders a "Debug" tab inside the collapsed Details panel.
# Default (not set or 0): Debug tab is hidden; no raw data sent to client.
# DEV_DEBUG_UI=0
